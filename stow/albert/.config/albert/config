[General]
frontend=widgetsboxmodel-ng
showTray=true
telemetry=false

[application]
enabled=true

[applications]
enabled=true
terminal=kitty

[calculator_qalculate]
enabled=true

[files]
enabled=true
home\acuervo\Documents\followSymlinks=false
home\acuervo\Documents\indexhidden=true
home\acuervo\Documents\maxDepth=3
home\acuervo\Documents\mimeFilters=inode/directory
home\acuervo\Documents\nameFilters=@Invalid()
home\acuervo\Documents\scanInterval=5
home\acuervo\Documents\useFileSystemWatches=false
home\acuervo\Downloads\followSymlinks=false
home\acuervo\Downloads\indexhidden=false
home\acuervo\Downloads\maxDepth=2
home\acuervo\Downloads\mimeFilters=inode/directory
home\acuervo\Downloads\nameFilters=@Invalid()
home\acuervo\Downloads\scanInterval=5
home\acuervo\Downloads\useFileSystemWatches=false
home\acuervo\Workspace\followSymlinks=false
home\acuervo\Workspace\indexhidden=true
home\acuervo\Workspace\maxDepth=3
home\acuervo\Workspace\mimeFilters=inode/directory
home\acuervo\Workspace\nameFilters=@Invalid()
home\acuervo\Workspace\scanInterval=5
home\acuervo\Workspace\useFileSystemWatches=false
home\acuervo\dotfiles\followSymlinks=false
home\acuervo\dotfiles\indexhidden=false
home\acuervo\dotfiles\maxDepth=3
home\acuervo\dotfiles\mimeFilters=inode/directory
home\acuervo\dotfiles\nameFilters=@Invalid()
home\acuervo\dotfiles\scanInterval=5
home\acuervo\dotfiles\useFileSystemWatches=false
paths=/home/acuervo/Documents, /home/acuervo/Downloads, /home/acuervo/Workspace, /home/acuervo/dotfiles
scanInterval=10
useFileSystemWatches=true

[system]
command_lock=~/.config/i3/scripts/i3lock.sh
command_logout=i3-msg exit
command_reboot=systemctl reboot
enabled=true

[websearch]
enabled=true

[widgetsboxmodel]
action_item_padding=6
action_item_selection_border_radius=11
action_item_selection_border_width=0
alwaysOnTop=false
clearOnHide=true
disable_input_method=true
displayScrollbar=true
followCursor=true
hideOnFocusLoss=true
historySearch=true
input_border_radius=11
input_font_size=18
input_padding=5
itemCount=8
result_item_horizontal_spacing=6
result_item_icon_size=39
result_item_padding=6
result_item_selection_border_radius=11
result_item_selection_border_width=0
result_item_subtext_font_size=8
result_item_text_font_size=13
result_item_vertical_spacing=2
showCentered=true
window_border_radius=18
window_border_width=1
window_padding=7
window_shadow_offset=8
window_shadow_size=80
window_spacing=7
window_width=640

[widgetsboxmodel-ng]
alwaysOnTop=false
clearOnHide=true
darkTheme=Catppuccin Mocha
displayScrollbar=true
followCursor=true
hideOnFocusLoss=true
historySearch=true
itemCount=8
